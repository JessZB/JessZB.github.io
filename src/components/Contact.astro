---
// Contact — theme-aware terminal header + full i18n via data-i18n attrs
import identity from '../data/identity.json';
---

<section id="contact" class="section-dark relative overflow-hidden">
  <div class="section-container" data-animate>

    <h2 class="section-title text-center neon-line pb-4" data-i18n="contact.title">Contacto</h2>
    <p class="section-subtitle text-center" data-i18n="contact.subtitle">¿Hablamos?</p>

    <div class="section-divider"></div>

    <div class="max-w-2xl mx-auto">
      <div class="card-base p-6 sm:p-8 border-primary/10">

        <!-- Terminal header — theme-aware -->
        <div class="relative mb-8 px-4 pb-4 pt-8 bg-bg-deep rounded-lg border border-primary/10 font-mono text-sm text-text-muted overflow-hidden">
          <!-- Traffic lights + title bar -->
          <div class="absolute top-0 left-0 right-0 h-7 bg-bg-surface/80 flex items-center gap-1.5 px-3 rounded-t-lg">
            <span class="w-2.5 h-2.5 rounded-full bg-accent hover:opacity-80 transition-opacity cursor-default"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-primary hover:opacity-80 transition-opacity cursor-default"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-secondary hover:opacity-80 transition-opacity cursor-default"></span>
            <span class="text-xs text-text-muted ml-2 font-mono" id="terminal-title">terminal.exe</span>
          </div>

          <!-- Terminal lines -->
          <div class="space-y-1">
            <p>
              <span id="terminal-user" class="text-secondary" data-i18n-arepa="contact.terminal.arepa" data-i18n-coffee="contact.terminal.coffee">arepa@jesszb.dev</span>
              <span class="text-text-muted">:</span>
              <span class="text-highlight-light">~</span>
              <span class="text-text-primary">$ </span>
              <span id="terminal-cmd" data-i18n-arepa="contact.init.arepa" data-i18n-coffee="contact.init.coffee">iniciar_contacto.sh</span>
            </p>
            <p class="text-text-muted" id="terminal-msg" data-i18n-arepa="contact.initMessage.arepa" data-i18n-coffee="contact.initMessage.coffee">
              Inicializando protocolo de comunicación...
            </p>
            <p class="text-secondary flex items-center gap-1">
              <span class="terminal-cursor inline-block w-2 h-4 bg-current animate-pulse rounded-sm"></span>
            </p>
          </div>
        </div>

        <!-- Form -->
        <form id="contact-form" class="space-y-5" novalidate>
          <!-- Honeypot -->
          <div class="hidden">
            <label>Don't fill this out if you're human: <input name="_gotcha" /></label>
          </div>

          <div>
            <label for="contact-name" class="block font-mono text-sm text-secondary mb-2" data-i18n="contact.name">
              echo "¿Cuál es tu nombre?"
            </label>
            <input
              id="contact-name"
              type="text"
              name="name"
              required
              autocomplete="name"
              class="contact-input w-full"
              data-i18n-placeholder="contact.namePlaceholder"
              placeholder="Escribe tu nombre"
            />
          </div>

          <div>
            <label for="contact-email" class="block font-mono text-sm text-secondary mb-2" data-i18n="contact.email">
              echo "¿Tu correo electrónico?"
            </label>
            <input
              id="contact-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              class="contact-input w-full"
              data-i18n-placeholder="contact.emailPlaceholder"
              placeholder="Escribe tu@email.com"
            />
          </div>

          <div>
            <label for="contact-message" class="block font-mono text-sm text-secondary mb-2" data-i18n="contact.message">
              echo "¿Qué tienes en mente?"
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              required
              class="contact-input w-full resize-none"
              data-i18n-placeholder="contact.messagePlaceholder"
              placeholder="Escribe tu mensaje"
            ></textarea>
          </div>

          <button
            type="submit"
            id="contact-submit"
            class="btn-primary w-full justify-center text-base py-3.5 flex items-center gap-2 group relative overflow-hidden"
          >
            <div id="submit-idle" class="flex items-center gap-2 transition-all duration-300">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
              </svg>
              <span data-i18n="contact.send">Enviar Mensaje</span>
            </div>
            
            <div id="submit-loading" class="hidden absolute inset-0 items-center justify-center bg-primary">
               <svg class="animate-spin h-5 w-5 text-bg-surface" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span class="ml-2 text-bg-surface font-bold text-sm" data-i18n="contact.sending">Enviando...</span>
            </div>
          </button>
        </form>

        <!-- Success state -->
        <div id="form-success" class="hidden text-center py-8">
          <div class="mb-6 flex justify-center" id="success-icon">
            <!-- SVG will be injected here -->
          </div>
          <p class="font-heading text-xl text-primary glow-text" data-i18n="contact.success">¡Chévere! Mensaje enviado con éxito</p>
          <p class="text-text-muted text-sm mt-2" data-i18n="contact.successAlt">Mientras tanto, también podés contactarme en mis redes sociales</p>
          
          <div class="mt-8 pt-6 border-t border-primary/10">
            <p class="text-text-muted text-sm mb-3" data-i18n="contact.directEmail">O si preferís, escribime directo a</p>
            <a href={`mailto:${identity.identity.email}`} class="inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors font-mono text-sm group">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              {identity.identity.email}
            </a>
          </div>
        </div>

        <!-- Error state -->
        <div id="form-error" class="hidden text-center py-8">
          <div class="mb-6 flex justify-center text-accent drop-shadow-[0_0_15px_rgba(255,100,100,0.3)]">
            <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <p class="font-heading text-xl text-accent glow-text" data-i18n="contact.error">¡Ups! Algo salió mal.</p>
          <p class="text-text-muted text-sm mt-2" data-i18n="contact.errorDetail">No se pudo enviar el mensaje. Por favor, intentá de nuevo.</p>
          <button id="btn-retry" class="btn-primary mt-6 mx-auto px-8 py-2 text-sm flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
            <span data-i18n="contact.retry">Reintentar</span>
          </button>
        </div>
      </div>

      <!-- Social links -->
      <div class="mt-10 text-center">
        <p class="text-text-muted text-sm mb-4" data-i18n="contact.alt">O encontrame en:</p>
        <div class="flex justify-center gap-6">
          <a href={`mailto:${identity.identity.email}`} class="social-link" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span class="text-sm">Email</span>
          </a>
          <a href={identity.identity.social.github} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            <span class="text-sm">GitHub</span>
          </a>
          <a href={identity.identity.social.linkedin} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            <span class="text-sm">LinkedIn</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Ambient -->
  <div class="absolute -top-20 right-0 w-72 h-72 bg-primary/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -bottom-20 left-0 w-72 h-72 bg-secondary/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>
</section>

<style>
  .contact-input {
    padding: 0.75rem 1rem;
    background: var(--color-bg-deep);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 0.875rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .contact-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .contact-input:focus {
    outline: none;
    border-color: rgba(var(--color-primary-raw, 245 197 66), 0.5);
    box-shadow: var(--shadow-glow-gold);
  }

  [data-theme="coffee"] .contact-input:focus {
    box-shadow: var(--shadow-glow-gold);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .social-link:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }
</style>

<script>
  let themeObserver: MutationObserver | null = null;
  let formSubmitHandler: ((e: Event) => void) | null = null;

  function initContact(): void {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('form-success');
    const errorState = document.getElementById('form-error');
    const successIcon = document.getElementById('success-icon');
    const terminalTitle = document.getElementById('terminal-title');
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const submitIdle = document.getElementById('submit-idle');
    const submitLoading = document.getElementById('submit-loading');
    const retryBtn = document.getElementById('btn-retry');

    const SUCCESS_ICONS = {
      arepa: `
        <div class="relative inline-flex flex-col items-center">
          <svg width="70" height="70" viewBox="0 0 100 100" class="text-primary drop-shadow-[0_0_15px_rgba(245,197,66,0.3)]">
            <circle cx="50" cy="50" r="40" fill="currentColor" opacity="0.1" stroke="currentColor" stroke-width="2"/>
            <path d="M30 50 Q50 65 70 50" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <circle cx="50" cy="50" r="32" fill="none" stroke="currentColor" stroke-width="1" opacity="0.2" stroke-dasharray="4 4"/>
          </svg>
          <div class="absolute -bottom-1 -right-1 bg-bg-surface rounded-full p-1 border border-primary shadow-lg scale-110">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A085" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
        </div>
      `,
      coffee: `
        <div class="relative inline-flex flex-col items-center">
          <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary drop-shadow-[0_0_15px_rgba(200,135,74,0.3)]">
            <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
            <line x1="6" y1="2" x2="6" y2="4"/>
            <line x1="10" y1="2" x2="10" y2="4"/>
            <line x1="14" y1="2" x2="14" y2="4"/>
          </svg>
          <div class="absolute -bottom-1 -right-1 bg-bg-surface rounded-full p-1 border border-primary shadow-lg scale-110">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A085" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
        </div>
      `
    };

    // Disconnect existing observer before re-creating
    if (themeObserver) {
      themeObserver.disconnect();
      themeObserver = null;
    }

    // Remove old form handler before re-attaching
    if (formSubmitHandler) {
      form?.removeEventListener('submit', formSubmitHandler);
    }

    // Sync terminal title with theme
    function updateTerminalTheme(): void {
      const theme = (document.documentElement.getAttribute('data-theme') as 'arepa' | 'coffee') || 'arepa';
      if (terminalTitle) {
        terminalTitle.textContent = theme === 'coffee' ? 'coffee-shop.sh' : 'terminal.exe';
      }
      if (successIcon) {
        successIcon.innerHTML = SUCCESS_ICONS[theme] || SUCCESS_ICONS.arepa;
      }
    }

    updateTerminalTheme();

    const htmlEl = document.documentElement;
    themeObserver = new MutationObserver(updateTerminalTheme);
    themeObserver.observe(htmlEl, { attributes: true, attributeFilter: ['data-theme'] });

    function setBtnLoading(isLoading: boolean) {
      if (!submitBtn || !submitIdle || !submitLoading) return;
      if (isLoading) {
        submitBtn.disabled = true;
        submitIdle.classList.add('opacity-0', 'scale-95');
        submitLoading.classList.remove('hidden');
        submitLoading.classList.add('flex');
      } else {
        submitBtn.disabled = false;
        submitIdle.classList.remove('opacity-0', 'scale-95');
        submitLoading.classList.add('hidden');
        submitLoading.classList.remove('flex');
      }
    }

    function validateForm(formData: FormData): boolean {
      const name = formData.get('name') as string;
      const email = formData.get('email') as string;
      const message = formData.get('message') as string;
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      if (!name || name.trim().length < 2) return false;
      if (!email || !emailRegex.test(email)) return false;
      if (!message || message.trim().length < 5) return false;

      return true;
    }

    // Form submit
    if (form && success && errorState) {
      formSubmitHandler = async (e: Event) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        
        if (!validateForm(formData)) {
          form.reportValidity();
          return;
        }

        setBtnLoading(true);

        try {
          const response = await fetch('https://formspree.io/f/xzdwbrpj', {
            method: 'POST',
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          });

          if (response.ok) {
            form.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => {
              form.style.display = 'none';
              success.classList.remove('hidden');
              success.classList.add('animate-fade-in-up');
              setBtnLoading(false);
            }, 300);
          } else {
            throw new Error('Form submission failed');
          }
        } catch (err) {
          console.error('Contact form error:', err);
          form.classList.add('opacity-0', 'pointer-events-none');
          setTimeout(() => {
            form.style.display = 'none';
            errorState.classList.remove('hidden');
            errorState.classList.add('animate-fade-in-up');
            setBtnLoading(false);
          }, 300);
        }
      };
      form.addEventListener('submit', formSubmitHandler);
    }

    // Retry button
    if (retryBtn && form && errorState) {
      retryBtn.addEventListener('click', () => {
        errorState.classList.add('hidden');
        errorState.classList.remove('animate-fade-in-up');
        form.style.display = 'block';
        form.classList.remove('opacity-0', 'pointer-events-none');
      });
    }
  }

  document.addEventListener('astro:page-load', initContact);
</script>
