---
// LightboxGallery — Full-screen image viewer with keyboard navigation
// Triggered by clicking gallery thumbnails on project detail pages
---

<div id="lightbox-gallery" class="lightbox-overlay" aria-hidden="true" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div class="lightbox-backdrop"></div>

  <!-- Close button -->
  <button id="lightbox-close" class="lightbox-close" aria-label="Cerrar galería">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
    </svg>
  </button>

  <!-- Previous button -->
  <button id="lightbox-prev" class="lightbox-nav lightbox-prev" aria-label="Imagen anterior">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M15 18l-6-6 6-6"/>
    </svg>
  </button>

  <!-- Next button -->
  <button id="lightbox-next" class="lightbox-nav lightbox-next" aria-label="Imagen siguiente">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m9 18 6-6-6-6"/>
    </svg>
  </button>

  <!-- Image container -->
  <div class="lightbox-content">
    <img id="lightbox-image" src="" alt="" class="lightbox-image" />
    <div id="lightbox-counter" class="lightbox-counter"></div>
  </div>
</div>

<style>
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .lightbox-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(8px);
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 10;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.1);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 9999px;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-50%) scale(1.1);
  }

  .lightbox-prev { left: 1.25rem; }
  .lightbox-next { right: 1.25rem; }

  .lightbox-content {
    position: relative;
    z-index: 5;
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
    transition: opacity 0.2s ease;
  }

  .lightbox-counter {
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    font-family: monospace;
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .lightbox-nav {
      width: 2.25rem;
      height: 2.25rem;
    }
    .lightbox-prev { left: 0.5rem; }
    .lightbox-next { right: 0.5rem; }
    .lightbox-image {
      max-width: 95vw;
      max-height: 75vh;
    }
  }
</style>

<script>
  let images: string[] = [];
  let currentIndex = 0;
  let lightboxClickHandler: ((e: MouseEvent) => void) | null = null;
  let lightboxKeyHandler: ((e: KeyboardEvent) => void) | null = null;

  function initLightboxGallery(imgs: string[]): void {
    images = imgs;
    currentIndex = 0;

    const overlay = document.getElementById('lightbox-gallery');
    if (!overlay) return;

    // Remove old listeners
    if (lightboxClickHandler) {
      overlay.removeEventListener('click', lightboxClickHandler);
    }
    if (lightboxKeyHandler) {
      document.removeEventListener('keydown', lightboxKeyHandler);
    }

    lightboxClickHandler = (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      if (target.closest('#lightbox-close') || target.closest('.lightbox-backdrop')) {
        closeLightbox();
      } else if (target.closest('#lightbox-prev')) {
        navigate(-1);
      } else if (target.closest('#lightbox-next')) {
        navigate(1);
      }
    };
    overlay.addEventListener('click', lightboxClickHandler);

    lightboxKeyHandler = (e: KeyboardEvent) => {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    };
    document.addEventListener('keydown', lightboxKeyHandler);
  }

  function openLightbox(index: number): void {
    currentIndex = index;
    const overlay = document.getElementById('lightbox-gallery');
    if (!overlay) return;

    updateImage();
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox(): void {
    const overlay = document.getElementById('lightbox-gallery');
    if (!overlay) return;

    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  function navigate(direction: number): void {
    currentIndex = (currentIndex + direction + images.length) % images.length;
    updateImage();
  }

  function updateImage(): void {
    const img = document.getElementById('lightbox-image') as HTMLImageElement;
    const counter = document.getElementById('lightbox-counter');
    if (!img) return;

    img.style.opacity = '0';
    setTimeout(() => {
      img.src = images[currentIndex];
      img.alt = `Imagen ${currentIndex + 1} de ${images.length}`;
      img.style.opacity = '1';
    }, 150);

    if (counter) {
      counter.textContent = `${currentIndex + 1} / ${images.length}`;
    }
  }

  // Expose to global scope for thumbnail click handlers
  (window as any).__openLightbox = openLightbox;

  document.addEventListener('astro:page-load', () => {
    // Initialize with images from data attribute on the gallery container
    const gallery = document.getElementById('project-gallery');
    if (gallery) {
      const imgsData = gallery.getAttribute('data-images');
      if (imgsData) {
        const imgs = JSON.parse(imgsData) as string[];
        initLightboxGallery(imgs);
      }
    }
  });
</script>
