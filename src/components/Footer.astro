---
// Footer — JESSZB.DEV branding, theme-aware counter, full i18n
import identity from '../data/identity.json';
---

<footer class="bg-bg-deep border-t border-primary/10 relative overflow-hidden">
  <!-- Rainbow accent bar -->
  <div class="flex h-1">
    <div class="flex-1" style="background: var(--color-accent);"></div>
    <div class="flex-1" style="background: var(--color-primary);"></div>
    <div class="flex-1" style="background: var(--color-secondary);"></div>
    <div class="flex-1" style="background: var(--color-highlight);"></div>
  </div>

  <div class="section-container !py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">

      <!-- Brand -->
      <div class="text-center md:text-left">
        <a href="#hero" class="inline-block mb-2" aria-label="JESSZB.DEV — volver al inicio">
          <span class="font-heading text-2xl font-bold">
            <span class="text-primary glow-text">JESS</span><span class="zb-gradient">ZB</span><span class="text-accent">.</span><span class="text-primary glow-text">DEV</span>
          </span>
        </a>
        <p
          class="text-text-muted text-sm"
          data-i18n-arepa="footer.tagline.arepa"
          data-i18n-coffee="footer.tagline.coffee"
        >
          Código con sazón venezolana
        </p>
      </div>

      <!-- Right: socials + counter -->
      <div class="flex items-center gap-5">
        <!-- Socials -->
        <a href={identity.identity.social.github} target="_blank" rel="noopener noreferrer" class="footer-icon" aria-label="GitHub">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href={identity.identity.social.linkedin} target="_blank" rel="noopener noreferrer" class="footer-icon" aria-label="LinkedIn">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href={identity.identity.social.twitter} target="_blank" rel="noopener noreferrer" class="footer-icon" aria-label="Twitter / X">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        </a>

        <!-- Theme-aware counter -->
        <button
          id="fun-counter"
          class="flex items-center gap-2 px-4 py-2 bg-bg-surface rounded-full border border-primary/10 hover:border-primary/40 transition-all text-sm text-text-muted hover:text-primary group"
          title="¡Hacé click!"
          aria-label="Contador de diversión"
        >
          <span id="counter-emoji" class="text-lg group-hover:scale-125 transition-transform" aria-hidden="true">🧆</span>
          <span id="counter-count" class="font-mono font-medium">0</span>
          <span
            class="hidden sm:inline"
            data-i18n-arepa="footer.counter.arepa"
            data-i18n-coffee="footer.counter.coffee"
          >arepas consumidas</span>
        </button>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3 text-center">
      <p class="text-text-muted text-xs" data-i18n="footer.copyright">
        © 2026 JESS<span class="zb-gradient">ZB</span>.DEV — Jesús Zapata
      </p>
      <p class="text-text-muted text-xs opacity-50">
        Built with Astro · Tailwind · GSAP ♥
      </p>
    </div>
  </div>

  <!-- Ambient glows -->
  <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-secondary/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
</footer>

<style>
  .footer-icon {
    color: var(--color-text-muted);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .footer-icon:hover {
    color: var(--color-primary);
    transform: translateY(-3px);
  }
</style>

<script>
  let count = 0;
  let themeObserver: MutationObserver | null = null;

  function initFooter(): void {
    const btn = document.getElementById('fun-counter');
    const display = document.getElementById('counter-count');
    const emoji = document.getElementById('counter-emoji');

    // Disconnect existing observer before re-creating
    if (themeObserver) {
      themeObserver.disconnect();
      themeObserver = null;
    }

    // Reset counter state
    count = 0;
    if (display) display.textContent = '0';

    function getEmoji(): string {
      const theme = document.documentElement.getAttribute('data-theme') || 'arepa';
      return theme === 'coffee' ? '☕' : '🧆';
    }

    // Init emoji
    if (emoji) emoji.textContent = getEmoji();

    // Watch theme changes on <html>
    const htmlEl = document.documentElement;
    themeObserver = new MutationObserver(() => {
      if (emoji) emoji.textContent = getEmoji();
      count = 0;
      if (display) display.textContent = '0';
    });
    themeObserver.observe(htmlEl, { attributes: true, attributeFilter: ['data-theme'] });

    btn?.addEventListener('click', () => {
      count++;
      if (display) display.textContent = count.toString();

      btn.style.transform = 'scale(1.08)';
      setTimeout(() => {
        btn.style.transform = '';
      }, 150);

      if (count % 10 === 0) {
        btn.style.boxShadow = '0 0 20px var(--shadow-glow-gold)';
        setTimeout(() => {
          btn.style.boxShadow = '';
        }, 600);
      }
    });
  }

  document.addEventListener('astro:page-load', initFooter);
</script>
