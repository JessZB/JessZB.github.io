---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import LightboxGallery from '../../components/LightboxGallery.astro';
import { projects, getProjectBySlug, getRelatedProjects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug!);

if (!project) {
  return Astro.redirect('/');
}

const related = getRelatedProjects(project.slug, 3);

const colorMap: Record<string, { text: string; bg: string; border: string; chip: string; glow: string }> = {
  primary:   { text: 'text-primary', bg: 'bg-primary/10', border: 'border-primary/25', chip: 'bg-primary/15 text-primary border-primary/20', glow: 'shadow-glow-gold' },
  secondary: { text: 'text-secondary', bg: 'bg-secondary/10', border: 'border-secondary/25', chip: 'bg-secondary/15 text-secondary border-secondary/20', glow: 'shadow-glow-teal' },
  highlight: { text: 'text-highlight-light', bg: 'bg-highlight/10', border: 'border-highlight/25', chip: 'bg-highlight/15 text-highlight-light border-highlight/20', glow: 'shadow-glow-lavender' },
  accent:    { text: 'text-accent-light', bg: 'bg-accent/10', border: 'border-accent/25', chip: 'bg-accent/15 text-accent-light border-accent/20', glow: 'shadow-glow-coral' },
};

const c = colorMap[project.color] || colorMap.primary;
const hasImages = project.images && project.images.length > 0;

// Default lang es — i18n engine will swap on client
const lang: 'es' | 'en' = 'es';
const title = project.title;
const description = project.description[lang];
const fullDescription = project.fullDescription[lang];
const timeWorked = project.timeWorked[lang];
---

<Layout
  title={`${title} | JESSZB.DEV`}
  description={description}
  locale="es"
  canonicalPath={`/projects/${slug}`}
>
  <Navbar />

  <main class="min-h-screen bg-bg-deep">
    <!-- Hero banner -->
    <div class={`relative pt-24 pb-16 bg-gradient-to-b from-bg-surface to-bg-deep overflow-hidden`}>
      <div class="absolute inset-0 bg-grid opacity-30" aria-hidden="true"></div>
      {hasImages && (
        <div class="absolute inset-0 bg-cover bg-center blur-xl scale-110 opacity-40" style={`background-image: url('${project.images[0]}')`} aria-hidden="true"></div>
      )}
      {hasImages && (
        <div class="absolute inset-0 bg-gradient-to-b from-bg-surface/80 to-bg-deep/90" aria-hidden="true"></div>
      )}
      <!-- Ambient -->
      <div class={`absolute top-0 right-0 w-96 h-96 ${c.bg} rounded-full blur-[120px] pointer-events-none`} aria-hidden="true"></div>

      <div class="section-container relative z-10">
        <!-- Back link -->
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 text-text-muted hover:text-primary transition-colors text-sm mb-8 group"
          data-i18n="projects.detail.back"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform" aria-hidden="true"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          ← Volver a proyectos
        </a>

        <div class="flex flex-wrap items-start gap-4 mb-6">
          <!-- Status & category badges -->
          <span class={`tag text-xs border ${c.chip}`} data-i18n={`projects.status.${project.status}`}>
            {project.status === 'completed' ? 'Completado' : 'En desarrollo'}
          </span>
          <span class={`tag text-xs border ${c.chip}`} data-i18n={`projects.filters.${project.category}`}>
            {{own: 'Propios', collab: 'Colaborativos'}[project.category]}
          </span>
        </div>

        <h1 class={`font-heading text-4xl md:text-5xl lg:text-6xl font-bold mb-4 ${c.text}`}>
          {title}
        </h1>
        <p class="text-text-secondary text-lg max-w-2xl leading-relaxed mb-8" data-i18n-text-es={project.description.es} data-i18n-text-en={project.description.en}>
          {description}
        </p>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-4">
          {project.demo && project.demo !== '#' && (
            <a
              href={project.demo}
              class="btn-primary px-6 py-3 flex items-center gap-2"
              target="_blank"
              rel="noopener noreferrer"
              data-i18n="projects.demo"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              Demo
            </a>
          )}
          {project.code && project.code !== '#' && (
            <a
              href={project.code}
              class="btn-outline px-6 py-3 flex items-center gap-2"
              target="_blank"
              rel="noopener noreferrer"
              data-i18n="projects.code"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg>
              Código
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Main content grid -->
    <div class="section-container py-12">
      <div class="grid lg:grid-cols-3 gap-8">

        <!-- Left: full description + gallery -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Media Gallery -->
          <div class="card-base p-6 card-base--no-hover" data-animate>
            <h2 class={`font-heading text-xl font-semibold mb-4 ${c.text}`} data-i18n="projects.detail.gallery">
              Galería
            </h2>

          {hasImages ? (
            <!-- Gallery grid: show max 4 images + overlay for remaining -->
            <div id="project-gallery" class="grid grid-cols-2 gap-3" data-images={JSON.stringify(project.images)}>
              {project.images.slice(0, 4).map((img, i) => {
                const isLast = i === 3;
                const remaining = project.images.length - 4;
                return (
                  <div
                    class="aspect-video rounded-lg overflow-hidden bg-bg-surface border border-white/5 cursor-pointer group relative"
                    onclick={`__openLightbox(${i})`}
                  >
                    <Image
                      src={img}
                      alt={`${title} screenshot ${i + 1}`}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                      decoding="async"
                      inferSize
                      width={640}
                      height={360}
                    />
                    {isLast && remaining > 0 && (
                      <div class="absolute inset-0 bg-black/60 flex items-center justify-center group-hover:bg-black/70 transition-colors">
                        <span class="text-white font-heading text-2xl font-bold">+{remaining}</span>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          ) : (
              <!-- Placeholder gallery when no images -->
              <div class="grid grid-cols-2 gap-3">
                {[1, 2, 3, 4].map((i) => (
                  <div class={`aspect-video rounded-lg overflow-hidden border ${c.border} ${c.bg} flex items-center justify-center`}>
                    <div class="text-center">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={`mx-auto mb-2 ${c.text} opacity-40`} aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                      <p class="text-xs text-text-muted opacity-60">Screenshot {i}</p>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>

          <!-- Full Description -->
          <div class="card-base p-6" data-animate>
            <h2 class={`font-heading text-xl font-semibold mb-4 ${c.text}`} data-i18n="projects.detail.description">
              Descripción
            </h2>
            <p class="text-text-secondary leading-relaxed" data-i18n-text-es={project.fullDescription.es} data-i18n-text-en={project.fullDescription.en}>
              {fullDescription}
            </p>
          </div>

          <!-- Problems Solved -->
          {project.problemsSolved && (
            <div class="card-base p-6" data-animate>
              <h2 class={`font-heading text-xl font-semibold mb-4 ${c.text}`} data-i18n="projects.detail.problemsSolved">
                Problemas que resuelve
              </h2>
              <p class="text-text-secondary leading-relaxed" data-i18n-text-es={project.problemsSolved.es} data-i18n-text-en={project.problemsSolved.en}>
                {project.problemsSolved[lang]}
              </p>
            </div>
          )}

          <!-- Key Features -->
          {project.keyFeatures && (
            <div class="card-base p-6" data-animate>
              <h2 class={`font-heading text-xl font-semibold mb-4 ${c.text}`} data-i18n="projects.detail.keyFeatures">
                Funcionalidades destacadas
              </h2>
              <ul class="text-text-secondary leading-relaxed space-y-2">
                {project.keyFeatures[lang].map((feature, i) => (
                  <li class="flex items-start gap-2">
                    <span class={`mt-1.5 w-1.5 h-1.5 rounded-full ${c.bg} border ${c.border} shrink-0`} aria-hidden="true"></span>
                    <span data-i18n-text-es={project.keyFeatures!.es[i]} data-i18n-text-en={project.keyFeatures!.en[i]}>
                      {feature}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Architecture -->
          {project.architecture && (
            <div class="card-base p-6" data-animate>
              <h2 class={`font-heading text-xl font-semibold mb-4 ${c.text}`} data-i18n="projects.detail.architecture">
                Arquitectura
              </h2>
              <p class="text-text-secondary leading-relaxed" data-i18n-text-es={project.architecture.es} data-i18n-text-en={project.architecture.en}>
                {project.architecture[lang]}
              </p>
            </div>
          )}
        </div>

        <!-- Right: metadata sidebar -->
        <div class="space-y-6">

          <!-- Time worked -->
          <div class={`card-base p-5 border ${c.border}`} data-animate>
            <h3 class={`font-heading text-sm font-semibold uppercase tracking-wider ${c.text} mb-2`} data-i18n="projects.detail.timeWorked">
              Tiempo de desarrollo
            </h3>
            <p class="text-text-primary font-medium text-lg" data-i18n-text-es={project.timeWorked.es} data-i18n-text-en={project.timeWorked.en}>{timeWorked}</p>
          </div>

          <!-- Tech Stack -->
          <div class={`card-base p-5 border ${c.border} ${c.glow}`} data-animate>
            <h3 class={`font-heading text-sm font-semibold uppercase tracking-wider ${c.text} mb-4`} data-i18n="projects.detail.techStack">
              Stack tecnológico
            </h3>
            <div class="flex flex-wrap gap-2">
              {project.techs.map((tech) => (
                <span class={`text-xs font-medium px-3 py-1.5 rounded-full border ${c.chip}`}>
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <!-- Tools -->
          {project.tools && project.tools.length > 0 && (
            <div class={`card-base p-5 border ${c.border}`} data-animate>
              <h3 class={`font-heading text-sm font-semibold uppercase tracking-wider ${c.text} mb-4`} data-i18n="projects.detail.tools">
                Herramientas
              </h3>
              <div class="flex flex-wrap gap-2">
                {project.tools.map((tool) => (
                  <span class="tag text-xs">{tool}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Back to home -->
          <a
            href="/"
            class="btn-outline w-full text-center py-3 flex items-center justify-center gap-2 text-sm"
            data-i18n="projects.detail.backHome"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            Ir al inicio
          </a>
        </div>
      </div>

      <!-- Related Projects -->
      <div class="mt-16" data-animate>
        <h2 class="font-heading text-2xl font-bold text-text-primary mb-2" data-i18n="projects.detail.otherProjects">
          Otros proyectos
        </h2>
        <div class="section-divider mb-8"></div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {related.map((p) => (
            <ProjectCard project={p} lang="es" />
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />

  {hasImages && <LightboxGallery />}
</Layout>
